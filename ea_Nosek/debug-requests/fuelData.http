  "turbocharger": "None",
  "fuelType": "Gasoline",
  "cityMpgFt1": 30,
  "highwayMpgFt1": 38,
  "unroundedCityMpgFt1": 30.0,
  "unroundedHighwayMpgFt1": 38.0,
  "combinedMpg": 34,
  "annualFuelCostFt1": 1100,
  "annualConsumptionInBarrelsFt1": 11,
  "tailpipeCo2InGramsMileFt1": 290
